# ──────────────────────────────────────
# 데이터 폴더: 폴더 구조만 유지, 내용물 제외
# ──────────────────────────────────────

# ref/ — 레퍼런스 제안서 (PPTX, PDF 등 대용량)
ref/*
!ref/.gitkeep

# input/ — RFP 입력 문서
input/*
!input/.gitkeep

# output/ — 생성된 PPTX 및 스크립트
output/*
!output/.gitkeep

# ──────────────────────────────────────
# Think Tank DB (SQLite)
# ──────────────────────────────────────
think_tank/*.db
think_tank/*.sqlite

# ──────────────────────────────────────
# Claude Code 내부
# ──────────────────────────────────────
.claude/*
!.claude/skills/
